.claude/
.gradle/
.kotlin/
build/
/local.properties

# The CI workflow generates the Gradle wrapper on-the-fly with
# `gradle wrapper --gradle-version 8.9` so we deliberately don't commit it.
/gradlew
/gradlew.bat
/gradle/wrapper/gradle-wrapper.jar
/.idea/*
!/.idea/codeStyles
!/.idea/inspectionProfiles
.DS_Store
/captures
.externalNativeBuild
.cxx
*.apk
*.aab
*.cbz

# Release signing artefacts. Never commit. Back them up out-of-band
# (password manager, encrypted cloud) — see RELEASE.md.
*.jks
*.p12
*.pfx
keystore.properties
*.keystore
!debug.keystore
